---
import Layout from '../layouts/Layout.astro';

const featured = {
  title: 'Portal compartido',
  text: 'Tus propiedades publicadas quedan visibles en el tráfico de todo el portal Predia, no solo en tu propio sitio.',
  icon: 'globe',
  image: 'https://images.unsplash.com/photo-1554469384-e58fac16e23a?w=1200&q=80&auto=format&fit=crop',
};

const rest = [
  {
    title: 'CRM propio',
    text: 'Gestioná propiedades, agentes y clientes potenciales por etapas (nuevo, contactado, calificado, propuesta, negociación) desde un panel dedicado a tu agencia.',
    icon: 'building',
  },
  {
    title: 'Visibilidad por agente',
    text: 'Cada agente ve solo sus propios clientes potenciales asignados. Como administrador, vos ves todo el equipo.',
    icon: 'shield',
  },
  {
    title: 'Pago simple',
    text: 'Suscripción mensual, confirmación de pago vía SINPE Móvil.',
    icon: 'card',
  },
];

const icons: Record<string, string> = {
  building: 'M6 21V5a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v16M6 21h12M6 21H4m14 0h2M9 8h1M9 12h1M9 16h1M14 8h1M14 12h1M14 16h1',
  globe: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm-9-9h18M12 3c2.5 2.5 3.8 5.6 3.8 9s-1.3 6.5-3.8 9c-2.5-2.5-3.8-5.6-3.8-9s1.3-6.5 3.8-9Z',
  shield: 'M12 3.5 5 6v5.2c0 4.4 2.9 7.7 7 8.8 4.1-1.1 7-4.4 7-8.8V6l-7-2.5Z',
  card: 'M3.5 7h17a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1h-17a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Zm-1 4.5h19M6 15.5h4',
};
---

<Layout title="Predia para agencias" description="Sumá tu inmobiliaria al portal compartido de Predia: CRM, gestión de clientes potenciales y visibilidad en un solo lugar.">
	<section class="bg-ink">
		<div class="mx-auto grid max-w-6xl gap-12 px-6 py-20 md:grid-cols-2 md:items-center md:px-10 md:py-28">
			<div>
				<p class="eyebrow text-bg/55!">Para inmobiliarias y agencias</p>
				<h1 class="mt-4 text-4xl font-semibold leading-tight tracking-[-0.02em] text-bg md:text-5xl">
					Tu agencia, en el portal que ya buscan los compradores
				</h1>
				<p class="mt-6 max-w-md text-[1.02rem] leading-relaxed text-bg/70">
					Gestioná tu inventario, tus agentes y tus clientes potenciales desde un CRM propio, y
					publicá tus propiedades en el portal compartido de Predia.
				</p>
				<a href="#solicitar" class="sweep mt-9 inline-flex rounded-lg bg-bg px-7 py-3.5 text-sm font-medium text-ink shadow-soft">
					<span>Solicitar acceso</span>
				</a>
			</div>
			<div class="relative aspect-4/3 overflow-hidden rounded-xl">
				<img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=1200&q=80&auto=format&fit=crop" alt="" class="h-full w-full object-cover" loading="lazy" />
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-24 md:px-10">
		<div class="grid gap-6 md:grid-cols-2">
			<div data-reveal class="relative flex min-h-88 flex-col justify-end overflow-hidden rounded-xl">
				<img src={featured.image} alt="" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
				<div class="absolute inset-0 bg-linear-to-t from-ink/85 via-ink/25 to-transparent"></div>
				<div class="relative p-7">
					<span class="flex h-10 w-10 items-center justify-center rounded-lg bg-bg/15 backdrop-blur-sm">
						<svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#F7F7F8" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
							<path d={icons[featured.icon]} />
						</svg>
					</span>
					<h2 class="mt-4 text-2xl font-semibold tracking-[-0.01em] text-bg">{featured.title}</h2>
					<p class="mt-2 max-w-sm text-[0.92rem] leading-relaxed text-bg/80">{featured.text}</p>
				</div>
			</div>

			<div class="flex flex-col justify-between gap-8">
				{rest.map((f, i) => (
					<div data-reveal style={`transition-delay:${(i + 1) * 90}ms`} class="flex gap-5">
						<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg border border-border bg-surface shadow-soft">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1C2028" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
								<path d={icons[f.icon]} />
							</svg>
						</span>
						<div>
							<h3 class="text-lg font-semibold tracking-[-0.01em] text-ink">{f.title}</h3>
							<p class="mt-1.5 text-[0.92rem] leading-relaxed text-muted-dark">{f.text}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FORM PROPIO -->
	<section id="solicitar" class="border-t border-border bg-surface">
		<div class="mx-auto max-w-2xl px-6 py-24 md:px-10">
			<h2 class="text-center text-3xl font-semibold tracking-[-0.02em] text-ink md:text-4xl">Sumá tu agencia a Predia</h2>
			<p class="mt-4 text-center text-[0.95rem] text-muted-dark">
				Completá el formulario y te contactamos para configurar tu cuenta.
			</p>

			<form id="agencia-form" class="mt-10 space-y-5">
				<div class="grid gap-5 sm:grid-cols-2">
					<div>
						<label for="agencia" class="text-xs font-medium text-muted-dark">Nombre de la agencia</label>
						<input id="agencia" name="agencia" required class="mt-1.5 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-sm text-ink outline-none focus:border-ink" />
					</div>
					<div>
						<label for="contacto" class="text-xs font-medium text-muted-dark">Nombre de contacto</label>
						<input id="contacto" name="contacto" required class="mt-1.5 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-sm text-ink outline-none focus:border-ink" />
					</div>
					<div>
						<label for="email" class="text-xs font-medium text-muted-dark">Email</label>
						<input id="email" name="email" type="email" required class="mt-1.5 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-sm text-ink outline-none focus:border-ink" />
					</div>
					<div>
						<label for="telefono" class="text-xs font-medium text-muted-dark">Teléfono / WhatsApp</label>
						<input id="telefono" name="telefono" required class="mt-1.5 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-sm text-ink outline-none focus:border-ink" />
					</div>
				</div>
				<div>
					<label for="propiedades" class="text-xs font-medium text-muted-dark">Cantidad aproximada de propiedades a publicar</label>
					<input id="propiedades" name="propiedades" class="mt-1.5 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-sm text-ink outline-none focus:border-ink" />
				</div>
				<div>
					<label for="mensaje" class="text-xs font-medium text-muted-dark">Mensaje (opcional)</label>
					<textarea id="mensaje" name="mensaje" rows="3" class="mt-1.5 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-sm text-ink outline-none focus:border-ink"></textarea>
				</div>

				<button type="submit" class="sweep w-full rounded-lg bg-ink px-6 py-3.5 text-sm font-medium text-bg">
					<span>Enviar solicitud</span>
				</button>
				<p id="agencia-status" class="hidden text-center text-sm text-muted-dark" role="status"></p>
			</form>
		</div>
	</section>

	<script>
		// TODO: no hay endpoint publico todavia (predia-api Fase 5), esto simula el
		// envio en el cliente. Cuando exista el endpoint, reemplazar por un fetch real.
		const form = document.getElementById('agencia-form') as HTMLFormElement | null;
		const status = document.getElementById('agencia-status');
		form?.addEventListener('submit', (e) => {
			e.preventDefault();
			form.reset();
			if (status) {
				status.textContent = 'Gracias, te vamos a contactar en menos de 24 horas.';
				status.classList.remove('hidden');
			}
		});
	</script>
</Layout>
