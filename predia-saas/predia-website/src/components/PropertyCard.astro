---
import type { Property } from '../lib/types/property';
import { formatPrice } from '../lib/properties';

interface Props {
  property: Property;
}
const { property } = Astro.props;

const operationLabel: Record<Property['operation_type'], string> = {
  sale: 'Venta',
  rent: 'Alquiler',
  lease: 'Arrendamiento',
};

const locationLabel = property.location?.name ?? null;
const coverImage = property.images.find((img) => img.is_cover) ?? property.images[0] ?? null;
---

<a href={`/propiedades/${property.slug}`} class="group block">
	<div class="relative aspect-4/3 overflow-hidden rounded-xl bg-secondary">
		{coverImage ? (
			<img
				src={coverImage.url}
				alt={property.title}
				class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
				loading="lazy"
			/>
		) : (
			<div class="absolute inset-0 flex items-center justify-center">
				<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
					<rect x="3" y="4" width="18" height="16" rx="2" /><circle cx="9" cy="10" r="1.5" /><path d="m4 17 5-4 4 3 3-2.5L21 17" />
				</svg>
			</div>
		)}

		<span class="absolute left-3 top-3 rounded-md bg-bg/95 px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-wide text-ink shadow-soft">
			{operationLabel[property.operation_type]}
		</span>
	</div>

	<div class="mt-3.5">
		<p class="eyebrow">{property.category.name}{locationLabel ? ` · ${locationLabel}` : ''}</p>
		<h3 class="mt-1.5 text-[1.05rem] font-semibold tracking-[-0.01em] leading-snug text-ink transition-colors group-hover:text-muted-dark">
			{property.title}
		</h3>
		<p class="mt-1.5 text-[0.95rem] font-medium text-ink">{formatPrice(property)}</p>
	</div>
</a>
