---
const links = [
  { href: '/propiedades', label: 'Propiedades' },
  { href: '/para-agencias', label: 'Para agencias' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];
const path = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border/70 bg-bg/85 backdrop-blur-md">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 md:px-10">
		<a href="/" class="flex items-center gap-2.5">
			<img src="/brand/logo.jpg" width="30" height="30" alt="Predia" class="rounded-md" />
			<span class="font-display text-[1.2rem] font-semibold tracking-[-0.02em] leading-none text-ink">Predia</span>
		</a>

		<nav class="hidden items-center gap-9 md:flex">
			{links.map((l) => (
				<a
					href={l.href}
					class:list={[
						'text-[0.85rem] font-medium tracking-tight transition-colors hover:text-ink',
						path === l.href || path.startsWith(l.href + '/') ? 'text-ink' : 'text-muted',
					]}
				>
					{l.label}
				</a>
			))}
		</nav>

		<a
			href="/propiedades"
			class="sweep hidden rounded-lg bg-ink px-5 py-2.5 text-[0.8rem] font-medium text-bg shadow-soft md:inline-flex"
		>
			<span>Ver propiedades</span>
		</a>

		<details class="md:hidden">
			<summary class="list-none rounded-lg border border-border p-2" aria-label="Menú">
				<svg width="20" height="20" viewBox="0 0 20 20" fill="none">
					<path d="M2.5 5h15M2.5 10h15M2.5 15h15" stroke="#1C2028" stroke-width="1.4" stroke-linecap="round" />
				</svg>
			</summary>
			<div class="absolute inset-x-0 top-full flex flex-col gap-1 border-b border-border bg-surface px-6 py-4 shadow-lg">
				{links.map((l) => (
					<a href={l.href} class="rounded-lg px-2 py-2.5 text-sm text-ink hover:bg-bg">{l.label}</a>
				))}
			</div>
		</details>
	</div>
</header>
