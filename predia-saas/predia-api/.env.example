# Credenciales para el contenedor Docker local (docker-compose.yml en raíz del mono-repo).
# Para producción usar credenciales reales — nunca commitear .env con passwords reales.
DATABASE_URL="postgresql://predia_app:predia_app@localhost:5433/predia"
SYSTEM_DATABASE_URL="postgresql://predia_system:predia_system@localhost:5433/predia"
# Superuser para prisma migrate — necesita DDL (CREATE TABLE, ALTER TABLE)
MIGRATION_URL="postgresql://postgres:postgres@localhost:5433/predia"
JWT_SECRET="cambia-esto-en-produccion-min-32-chars"
JWT_REFRESH_SECRET="cambia-esto-tambien-en-produccion-min-32"
CORS_ORIGIN="http://localhost:5173"
APP_URL="http://localhost:5173"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@predia.com"
EMAIL_FROM_NAME="Predia"
EMAIL_ENABLED="true"   # set "false" to skip all sends in local/test

# Cloudinary (property images)
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"
