generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LocationType {
  province
  canton
  district
}

enum SubscriptionStatus {
  trial
  active
  past_due
  cancelled
}

enum UserRole {
  super_admin
  admin
  agent
}

enum UserStatus {
  active
  suspended
  invited
  deactivated
}

enum OperationType {
  sale
  rent
  lease
}

enum PropertyStatus {
  draft
  active
  inactive
  sold
  rented
  archived
}

enum CurrencyCode {
  CRC
  USD
}

enum LeadSource {
  web
  referral
  walk_in
  social
  other
}

enum LeadStatus {
  new
  contacted
  qualified
  proposal
  negotiation
  won
  lost
  archived
}

enum LeadActivityType {
  call
  email
  meeting
  note
  status_change
}

model Tenant {
  id                  String             @id @default(uuid())
  name                String
  slug                String             @unique
  subscription_status SubscriptionStatus @default(trial)
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  users               User[]
  site                TenantSite?
  properties          Property[]
  leads               Lead[]
  lead_activities     LeadActivity[]
}

model TenantSite {
  id              String   @id @default(uuid())
  tenant_id       String   @unique
  custom_domain   String?
  allowed_origins String?
  logo_url        String?
  primary_color   String?
  secondary_color String?
  font_family     String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("tenant_sites")
}

model User {
  id                      String               @id @default(uuid())
  tenant_id               String
  email                   String
  password_hash           String
  role                    UserRole             @default(agent)
  status                  UserStatus           @default(active)
  suspended_at            DateTime?
  first_name              String
  last_name               String
  created_at              DateTime             @default(now())
  updated_at              DateTime             @updatedAt
  tenant                  Tenant               @relation(fields: [tenant_id], references: [id])
  password_reset_tokens   PasswordResetToken[]
  properties              Property[]
  assigned_leads          Lead[]               @relation("LeadAssignee")
  created_lead_activities LeadActivity[]       @relation("LeadActivityCreator")

  @@unique([tenant_id, email])
  @@index([tenant_id])
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_tokens")
}

model Location {
  id         String       @id @default(uuid())
  name       String
  code       String       @unique
  type       LocationType
  parent_id  String?
  created_at DateTime     @default(now())
  parent     Location?    @relation("LocationHierarchy", fields: [parent_id], references: [id])
  children   Location[]   @relation("LocationHierarchy")
  properties Property[]

  @@index([type])
  @@index([parent_id])
  @@map("locations")
}

model Category {
  id               String     @id @default(uuid())
  name             String
  slug             String     @unique
  description      String?
  attribute_schema Json
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt
  properties       Property[]

  @@map("categories")
}

model AuditLog {
  id         String   @id @default(uuid())
  actor_id   String
  actor_role String
  action     String
  entity     String
  entity_id  String
  payload    Json
  tenant_id  String?
  created_at DateTime @default(now())

  @@index([tenant_id])
  @@index([actor_id])
  @@index([entity, entity_id])
  @@map("audit_log")
}

model Property {
  id             String         @id @default(uuid())
  tenant_id      String
  title          String
  slug           String
  description    String?
  price          Decimal        @db.Decimal(15, 2)
  operation_type OperationType
  status         PropertyStatus @default(draft)
  subtype        String?
  currency       CurrencyCode   @default(CRC)
  lot_area_m2    Decimal?       @db.Decimal(10, 2)
  built_area_m2  Decimal?       @db.Decimal(10, 2)
  address        String?
  lat            Decimal?       @db.Decimal(10, 6)
  lng            Decimal?       @db.Decimal(10, 6)
  location_id    String?
  category_id    String
  agent_id       String?
  attributes     Json           @default("{}")
  is_published   Boolean        @default(false)
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  tenant         Tenant         @relation(fields: [tenant_id], references: [id])
  location       Location?      @relation(fields: [location_id], references: [id])
  category       Category       @relation(fields: [category_id], references: [id])
  agent          User?          @relation(fields: [agent_id], references: [id])
  leads          Lead[]
  images         PropertyImage[]

  @@unique([tenant_id, slug])
  @@index([tenant_id])
  @@index([tenant_id, is_published])
  @@index([tenant_id, price])
  @@index([tenant_id, location_id])
  @@index([tenant_id, created_at])
  @@index([attributes], type: Gin)
  @@map("properties")
}

model PropertyImage {
  id          String   @id @default(uuid())
  property_id String
  tenant_id   String
  url         String
  position    Int
  is_cover    Boolean  @default(false)
  created_at  DateTime @default(now())
  property    Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@index([property_id, position])
  @@index([tenant_id])
  @@map("property_images")
}

model Lead {
  id          String         @id @default(uuid())
  tenant_id   String
  name        String
  email       String?
  phone       String?
  source      LeadSource     @default(other)
  status      LeadStatus     @default(new)
  assigned_to String?
  property_id String?
  notes       String?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  tenant      Tenant         @relation(fields: [tenant_id], references: [id])
  assignee    User?          @relation("LeadAssignee", fields: [assigned_to], references: [id])
  property    Property?      @relation(fields: [property_id], references: [id], onDelete: SetNull)
  activities  LeadActivity[]

  @@index([tenant_id, status])
  @@index([tenant_id, assigned_to])
  @@map("leads")
}

model LeadActivity {
  id          String           @id @default(uuid())
  lead_id     String
  tenant_id   String
  type        LeadActivityType
  description String
  created_by  String
  created_at  DateTime         @default(now())
  lead        Lead             @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant      Tenant           @relation(fields: [tenant_id], references: [id])
  creator     User             @relation("LeadActivityCreator", fields: [created_by], references: [id])

  @@index([lead_id, created_at])
  @@map("lead_activities")
}
